{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "copy-templates": "node -e \"const fs=require('fs'),path=require('path');const src=path.join(__dirname,'src','services','Email');const dest=path.join(__dirname,'dist','services','Email');fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).filter(f=>f.endsWith('.html')).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f)));console.log('Email templates copied.')\"",
    "build": "tsc && npm run copy-templates",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "start": "node dist/index.js",
    "prod": "npm run build && npm run db:push && npm run start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.43.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.1",
    "mysql2": "^3.18.2",
    "nodemailer": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
